{
  "name": "signalk-tailscale",
  "version": "0.1.0",
  "description": "Zero-config boat VPN: reach your SignalK server from anywhere over Tailscale, no port forwarding or DDNS",
  "main": "plugin/index.js",
  "type": "module",
  "signalk-plugin-enabled-by-default": true,
  "scripts": {
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx,html}\" && eslint --fix \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx}\"",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\" \"webapp/**/*.{ts,tsx}\"",
    "typecheck:webapp": "tsc -p tsconfig.webapp.json",
    "build:plugin": "tsc",
    "build:webapp": "vite build",
    "build": "npm run build:plugin && npm run typecheck:webapp && npm run build:webapp",
    "build:all": "npm run lint && npm run build && npm run test",
    "dev": "vite",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-embeddable-webapp",
    "signalk-category-utility",
    "tailscale",
    "vpn",
    "remote-access"
  ],
  "signalk": {
    "displayName": "Tailscale",
    "appIcon": "icon.svg",
    "requires": ["signalk-container"]
  },
  "files": ["plugin/**/*", "public/**/*", "assets/**/*", "docs/**/*"],
  "engines": {
    "node": ">=22.5.0",
    "signalk": ">=2.24.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@module-federation/vite": "^1.15.0",
    "@signalk/server-admin-ui-dependencies": "^2.23.0",
    "@signalk/server-api": "^2.24.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "bootstrap": "^5.3.8",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "express": "^5.2.1",
    "prettier": "^3.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reactstrap": "^9.2.3",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dirkwa/signalk-tailscale.git"
  },
  "license": "Apache-2.0"
}
